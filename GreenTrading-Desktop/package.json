{
  "name": "greentrading-desktop",
  "version": "0.1.0",
  "description": "GreenTrading Desktop - Trading application with MT5 integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --no-sandbox",
    "portable": "electron-builder --dir",
    "dist:portable": "electron-builder --dir"
  },
  "keywords": [
    "trading",
    "mt5",
    "smc",
    "electron"
  ],
  "author": "GreenTrading Team",
  "license": "MIT",
  "dependencies": {
    "electron": "^39.8.1"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.greentrading.desktop",
    "productName": "GreenTrading Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!.git",
      "!.gitignore"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "dir",
      "category": "Finance"
    },
    "mac": {
      "target": "dir",
      "category": "public.app-category.finance"
    }
  }
}
